PORT=3000
SERVER_HOST=0.0.0.0

# Public host/IP used to build noVNC URLs for LAN clients
# Example: 192.168.0.10
PUBLIC_HOST=
PUBLIC_PROTOCOL=http

# SSH connection to your game storage server
SSH_HOST=192.168.0.28
SSH_PORT=22
SSH_USERNAME=your_ssh_user
# SSH_PASSWORD=your_ssh_password
# Optional: use private key auth instead of password
SSH_PRIVATE_KEY_PATH=/run/user/1000/secrets/git/ssh/private

# Remote directory that contains game folders/files
REMOTE_GAMES_DIR=/mnt/data/media/torrents/game/windows

# Local installation base directory on this machine
LOCAL_INSTALL_BASE=/home/strange/Games

# Directory used for isolated desktop runtime files
SESSION_RUNTIME_BASE=/tmp/game-installer-sessions

# Isolated desktop display + ports (session i uses base+i)
ISOLATED_BASE_DISPLAY=90
ISOLATED_BASE_VNC_PORT=5901
ISOLATED_BASE_NOVNC_PORT=6081
ISOLATED_RESOLUTION=1600x900x24

# Optional: explicitly set noVNC web path (helpful on NixOS)
NOVNC_WEB_PATH=/run/current-system/sw/share/novnc

# Windows installer runtime on Linux: auto, wine, proton
WINDOWS_RUNTIME=auto
# Optional command overrides
# WINE_CMD=wine
# PROTON_CMD=proton
# Args passed before installer path when using Proton
# PROTON_ARGS=run

# Logging level: debug, info, warn, error
LOG_LEVEL=debug
